{
  "permissions": {
    "allow": [
      "Bash(bundle exec *)",
      "Bash(bundle install *)",

      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git branch *)",
      "Bash(git add *)",

      "Bash(gem build *)",
      "Bash(ruby *)",

      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(mkdir *)",

      "Bash(.claude/scripts/*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(shred *)",
      "Bash(find * -delete *)",

      "Bash(sudo *)",

      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git rebase *)",
      "Bash(git branch -D *)",

      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",

      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(killall *)",

      "Bash(diskutil *)",
      "Bash(launchctl *)",
      "Bash(defaults delete *)",
      "Bash(security find-generic-password *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/rubocop-autofix.sh"
          }
        ]
      }
    ]
  }
}
