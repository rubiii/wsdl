<?xml version="1.0" encoding="UTF-8"?>
<!--
  XSW Attack Fixture: Body Element in Wrong Position
  
  This document has the signed Body element wrapped inside another element
  (OriginalWrapper) instead of being a direct child of soap:Envelope.
  A malicious unsigned Body is placed in the correct position.
  
  The verifier would find the signed Body by ID and validate its digest,
  but the application would process the unsigned Body in the standard location.
  
  Expected behavior: Verifier should reject this document because the signed
  Body element is not a direct child of soap:Envelope.
-->
<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"
               xmlns:wsse="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"
               xmlns:wsu="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-utility-1.0.xsd">
  <soap:Header>
    <wsse:Security soap:mustUnderstand="1">
      <wsu:Timestamp wsu:Id="Timestamp-12345">
        <wsu:Created>2025-01-15T12:00:00.000Z</wsu:Created>
        <wsu:Expires>2025-01-15T12:05:00.000Z</wsu:Expires>
      </wsu:Timestamp>
      <wsse:BinarySecurityToken
        wsu:Id="SecurityToken-67890"
        ValueType="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-x509-token-profile-1.0#X509v3"
        EncodingType="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-soap-message-security-1.0#Base64Binary"></wsse:BinarySecurityToken>
      <ds:Signature xmlns:ds="http://www.w3.org/2000/09/xmldsig#">
        <ds:SignedInfo>
          <ds:CanonicalizationMethod Algorithm="http://www.w3.org/2001/10/xml-exc-c14n#"/>
          <ds:SignatureMethod Algorithm="http://www.w3.org/2001/04/xmldsig-more#rsa-sha256"/>
          <ds:Reference URI="#Body-wrapped">
            <ds:Transforms>
              <ds:Transform Algorithm="http://www.w3.org/2001/10/xml-exc-c14n#"/>
            </ds:Transforms>
            <ds:DigestMethod Algorithm="http://www.w3.org/2001/04/xmlenc#sha256"/>
            <ds:DigestValue>legitbodydigestvalue123456==</ds:DigestValue>
          </ds:Reference>
        </ds:SignedInfo>
        <ds:SignatureValue>fakesignaturevalue==</ds:SignatureValue>
        <ds:KeyInfo>
          <wsse:SecurityTokenReference>
            <wsse:Reference URI="#SecurityToken-67890"
                            ValueType="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-x509-token-profile-1.0#X509v3"/>
          </wsse:SecurityTokenReference>
        </ds:KeyInfo>
      </ds:Signature>
    </wsse:Security>
  </soap:Header>
  <!-- ATTACK: Unsigned malicious Body in the correct position (processed by application) -->
  <soap:Body>
    <TransferResponse xmlns="http://example.com/banking">
      <status>success</status>
      <amount>1000000.00</amount>
      <recipient>attacker@evil.com</recipient>
    </TransferResponse>
  </soap:Body>
  <!-- Original signed Body wrapped and hidden (validated by verifier but not processed) -->
  <OriginalWrapper>
    <soap:Body wsu:Id="Body-wrapped">
      <TransferResponse xmlns="http://example.com/banking">
        <status>success</status>
        <amount>10.00</amount>
        <recipient>legitimate@example.com</recipient>
      </TransferResponse>
    </soap:Body>
  </OriginalWrapper>
</soap:Envelope>